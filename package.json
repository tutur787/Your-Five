{
  "name": "5-aside-draft",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "shared",
    "worker",
    "client"
  ],
  "scripts": {
    "dev:worker": "npm run dev -w worker",
    "dev:client": "npm run dev -w client",
    "deploy:worker": "npm run deploy -w worker",
    "build:web": "npm run build -w client",
    "deploy:web": "npm run build:web && npx wrangler pages deploy client/dist --project-name your-five --branch main",
    "test:cloudflare": "npm run test:integration -w worker",
    "test:engine": "tsx shared/src/engine.test.ts",
    "test:reliability": "tsx shared/src/reliability.test.ts",
    "test:ai": "tsx shared/src/aiOpponent.test.ts",
    "test:ai-storage": "tsx client/src/utils/aiStorage.test.ts",
    "test:progress": "tsx client/src/utils/progressStorage.test.ts",
    "test:accounts": "tsx worker/src/accountProgress.test.ts",
    "test:soccer": "tsx shared/src/soccerEngine.test.ts",
    "data:soccer": "node scripts/generate-soccer-data.mjs",
    "verify:soccer-data": "node scripts/generate-soccer-data.mjs --verify"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "tsx": "^4.19.2",
    "@types/node": "^22.9.0"
  }
}
